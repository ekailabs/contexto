    "openclaw-plugin",
    "webhook",
    "events"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ekailabs/contexto",
    "directory": "packages/contexto"
  },
  "homepage": "https://github.com/ekailabs/contexto/tree/main/packages/contexto",
  "bugs": {
    "url": "https://github.com/ekailabs/contexto/issues"
  },
  "author": "Ekai Labs",
  "scripts": {
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@ekai/mindmap": "^0.1.8"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  },
  "openclaw": {
    "extensions": ["./src/index.ts"],
    "compat": {
