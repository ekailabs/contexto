{
  "name": "ekai-contexto",
  "version": "0.1.0-beta.1",
  "description": "Contexto - Local-First Context Engine for AI Agents",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm -r run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "dev:api": "pnpm --filter @ekai/api run dev",
    "dev:memory": "pnpm --filter @ekai/memory run dev",
    "dev:openrouter": "pnpm --filter @ekai/openrouter run dev",
    "dev:dashboard": "pnpm --filter @ekai/dashboard run dev",
    "dev:openclaw": "pnpm --filter @ekai/contexto run dev"
  },
  "devDependencies": {
    "typescript": "^5.3.2"
  },
  "keywords": [
    "ai",
    "memory",
    "context",
    "openclaw",
    "agent"
  ],
  "author": "Ekai Labs"
}