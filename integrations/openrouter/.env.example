# Required — your OpenRouter API key
OPENROUTER_API_KEY=your_key_here

# Memory service URL (optional, defaults to http://localhost:4005)
# MEMORY_URL=http://localhost:4005

# Server port (optional, defaults to 4010)
# PORT=4010

# Scheduled deduplicated ingest
# CONVERSATION_LOG_PATH=./data/conversation-log.jsonl
# INGEST_CHECKPOINT_PATH=./data/ingest-checkpoint.json
# MEMORY_INGEST_URL=http://localhost:4010
# INGEST_RATE_LIMIT_MS=1000
