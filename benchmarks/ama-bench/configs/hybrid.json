{
  "_comment": "MODE=hybrid — local Ollama embeddings (zero rate limits) + OpenAI for episodic/answer-gen/judge. No GPUs required. Requires Ollama + OPENAI_API_KEY in .env.",
  "embed": {
    "type": "ollama",
    "baseUrl": "http://localhost:11434",
    "model": "qwen3-embedding:0.6b"
  },
  "episodic": {
    "enabled": true,
    "baseUrl": "https://api.openai.com/v1/chat/completions",
    "model": "gpt-4.1-mini",
    "temperature": 0.2,
    "jsonMode": true,
    "noThink": false
  },
  "mindmap": {
    "similarityThreshold": 0.5,
    "maxDepth": 4,
    "maxChildren": 10,
    "rebuildInterval": 50
  },
  "search": {
    "maxResults": 10,
    "maxTokens": 4000,
    "beamWidth": 3,
    "minScore": 0.0
  }
}
